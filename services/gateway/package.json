{
  "name": "@locallink/gateway",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "prisma generate && vitest run",
    "test:coverage": "prisma generate && vitest run --coverage",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.11",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.3",
    "@locallink/shared": "workspace:*",
    "@locallink/validators": "workspace:*",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^6.2.1",
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "prisma": "^6.2.1",
    "resend": "^6.12.3",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@locallink/tsconfig": "workspace:*",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.3"
  }
}
